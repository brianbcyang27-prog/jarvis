// ── Voice message handler — transcribe and respond with voice+text ─
bot.on('message:voice', async ctx => {
  const chatId = ctx.chat.id;
  const userId = ctx.from.id;
  const voice = ctx.message.voice;

  console.log(`[${new Date().toLocaleTimeString()}] VOICE received — duration: ${voice.duration}s`);

  await bot.api.sendChatAction(chatId, 'typing');

  try {
    // Download voice file
    const fileInfo = await bot.api.getFile(voice.file_id);
    const fileUrl = `https://api.telegram.org/file/bot${BOT_TOKEN}/${fileInfo.file_path}`;

    // Download to temp file
    const oggPath = path.join(os.tmpdir(), `jarvis_voice_${Date.now()}.ogg`);
    const wavPath = oggPath.replace('.ogg', '.wav');

    await new Promise((resolve, reject) => {
      const file = fs.createWriteStream(oggPath);
      https.get(fileUrl, res => { res.pipe(file); file.on('finish', resolve); })
        .on('error', reject);
    });

    // Convert OGG to WAV using ffmpeg
    await new Promise((resolve, reject) => {
      exec(`ffmpeg -y -i "${oggPath}" -ar 16000 -ac 1 "${wavPath}"`, { timeout: 30000 }, (err) => {
        if (err) reject(err);
        else resolve();
      });
    });

    // Transcribe using Whisper
    const whisperResult = await new Promise((resolve, reject) => {
      exec(`python3 -c "import whisper; model = whisper.load_model('base'); result = model.transcribe('${wavPath}'); print(result['text'])"`, 
        { timeout: 60000 }, (err, stdout, stderr) => {
          if (err) reject(err);
          else resolve(stdout.trim());
        });
    });

    const transcribedText = whisperResult || '(empty)';
    console.log(`[${new Date().toLocaleTimeString()}] Transcribed: "${transcribedText}"`);

    // Clean up temp files
    fs.unlinkSync(oggPath);
    fs.unlinkSync(wavPath);

    // Process with AI
    jarvisLog('telegram_chat', `USER [voice]: ${transcribedText}`);

    // Get AI response
    const response = await getAIResponse(userId, transcribedText);

    // Send text response
    await bot.api.sendMessage(chatId, response.text, { parse_mode: 'Markdown' });

    // Generate voice response using macOS say command
    const voicePath = path.join(os.tmpdir(), `jarvis_response_${Date.now()}.aac`);
    await new Promise((resolve) => {
      // Use Daniel voice (British English, sounds like JARVIS)
      exec(`say -v Daniel "${response.text.replace(/"/g, '\\"').slice(0, 500)}" -o "${voicePath}"`, 
        { timeout: 30000 }, () => resolve());
    });

    // Send voice response
    if (fs.existsSync(voicePath)) {
      await bot.api.sendVoice(chatId, Input.fromPath(voicePath), { caption: '🔊 Voice response' });
      fs.unlinkSync(voicePath);
    }

    jarvisLog('telegram_chat', `JARVIS: ${response.text.slice(0, 200)}`);

  } catch (e) {
    console.error('Voice error:', e.message);
    await bot.api.sendMessage(chatId, E.red + ' Voice processing error: ' + e.message.slice(0, 100));
  }
});

// ── Helper: Get AI response (for voice handler) ─────────────────────
function getAIResponse(userId, userMsg) {
  return new Promise((resolve) => {
    const brain = getStatus();

    if (brain.type === 'nvidia') {
      const model = 'meta/llama-3.1-405b-instruct';
      const apiKey = getNvidiaApiKey();

      if (!conversations[userId]) conversations[userId] = [];
      conversations[userId].push({ role: 'user', content: userMsg });
      if (conversations[userId].length > MAX_HISTORY)
        conversations[userId] = conversations[userId].slice(-MAX_HISTORY);

      const messages = [
        { role: 'system', content: JARVIS_SYSTEM },
        ...conversations[userId]
      ];

      const body = JSON.stringify({
        model,
        messages,
        max_tokens: 300,
        temperature: 0.75,
        stream: false
      });

      const req = https.request({
        hostname: 'integrate.api.nvidia.com',
        port: 443,
        path: '/v1/chat/completions',
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${apiKey}`
        }
      }, res => {
        let data = '';
        res.on('data', d => data += d);
        res.on('end', () => {
          try {
            const d = JSON.parse(data);
            const final = d.choices?.[0]?.message?.content?.trim() || '...';
            conversations[userId].push({ role: 'assistant', content: final });
            bridgeMsg('assistant', final);
            resolve({ text: final });
          } catch (e) {
            resolve({ text: 'Error processing request, sir.' });
          }
        });
      });
      req.on('error', () => resolve({ text: 'Connection error, sir.' }));
      req.setTimeout(30000, () => { req.destroy(); resolve({ text: 'Request timeout, sir.' }); });
      req.write(body);
      req.end();
    } else {
      // Ollama fallback
      const isM4 = brain.current === 'm4';
      const host = isM4 ? '192.168.50.192' : 'localhost';
      const model = isM4 ? 'qwen2.5:14b' : 'qwen2.5:3b';

      if (!conversations[userId]) conversations[userId] = [];
      conversations[userId].push({ role: 'user', content: userMsg });

      const history = conversations[userId].slice(0, -1)
        .map(m => (m.role === 'user' ? 'User: ' : 'JARVIS: ') + m.content).join('\n');
      const prompt = history ? history + '\nUser: ' + userMsg + '\nJARVIS:' : userMsg;

      const body = JSON.stringify({
        model,
        system: JARVIS_SYSTEM,
        prompt,
        stream: false,
        options: { num_predict: 300, temperature: 0.75, num_ctx: 4096 }
      });

      const req = http.request({
        hostname: host, port: 11434,
        path: '/api/generate', method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      }, res => {
        let data = '';
        res.on('data', d => data += d);
        res.on('end', () => {
          try {
            const d = JSON.parse(data);
            const final = d.response?.trim() || '...';
            conversations[userId].push({ role: 'assistant', content: final });
            bridgeMsg('assistant', final);
            resolve({ text: final });
          } catch (e) {
            resolve({ text: 'Error processing request, sir.' });
          }
        });
      });
      req.on('error', () => resolve({ text: 'Connection error, sir.' }));
      req.setTimeout(30000, () => { req.destroy(); resolve({ text: 'Request timeout, sir.' }); });
      req.write(body);
      req.end();
    }
  });
}

// ── Photo handler — works regardless of active agent ───────────────
bot.on('message:photo', async ctx=>{
  const chatId=ctx.chat.id;
  const caption=(ctx.message.caption||'').trim();
  const photo=ctx.message.photo;
  const fileId=photo[photo.length-1].file_id; // largest size
  console.log(`[${new Date().toLocaleTimeString()}] PHOTO received — caption: "${caption}"`);
  await analyseImage(fileId, chatId, caption);
});

// ── Document handler (images sent as files) ────────────────────────
bot.on('message:document', async ctx=>{
  const chatId=ctx.chat.id;
  const doc=ctx.message.document;
  if(doc.mime_type&&doc.mime_type.startsWith('image/')){
    const caption=(ctx.message.caption||'').trim();
    console.log(`[${new Date().toLocaleTimeString()}] IMAGE DOC received`);
    await analyseImage(doc.file_id, chatId, caption);
  } else {
    await ctx.reply(E.zap+' Document received. Switch to '+E.laptop+' Coder agent to work with files, sir.');
  }
});

// ── Text messages ─────────────────────────────────────────────────
bot.on('message:text', async ctx=>{
  const text=ctx.message.text.trim(), chatId=ctx.chat.id, userId=ctx.from.id;
  const agent=getAgent(userId);
  console.log(`[${new Date().toLocaleTimeString()}] ${userId} → ${agent} | "${text.slice(0,60)}"`);
  // Bridge user message to dashboard + log it
  if(!text.startsWith('/')) {
    bridgeMsg('user', text, 'telegram');
    jarvisLog('telegram_chat', `USER [${agent}]: ${text}`);
  }

  if(agent==='coder'){
    await ctx.reply(E.laptop+' On it, sir...');
    handleCodingTask(text,chatId,(reply,md=false)=>{
      bot.api.sendMessage(chatId,reply,md?{parse_mode:'Markdown'}:{})
        .catch(()=>bot.api.sendMessage(chatId,reply.replace(/`/g,'')));
    });
    return;
  }
  if(agent==='printer'){
    handle3DPrint(text, chatId);
    return;
  }
  if(agent==='vision'){
    await ctx.reply(E.camera+' Send me an image to analyse, sir. You can also caption it with a question.');
    return;
  }
if(agent==='researcher'||agent==='planner'){
bot.api.sendChatAction(chatId,'typing').catch(()=>{});
runAgent(agent,text,chatId);
return;
}
askAI(userId,text,chatId);
});

bot.catch(err => {
  console.error('grammy error:', err.message);
  // Don't crash on 409 conflicts — they resolve after Telegram releases the old session
});

// Force-clear any conflicting Telegram sessions before starting
async function clearTelegramSessions() {
  return new Promise(resolve => {
    // Hit getUpdates with high offset to release any stuck polling
    const req = require('https').request({
      hostname: 'api.telegram.org', port: 443, method: 'GET',
      path: `/bot${BOT_TOKEN}/getUpdates?offset=999999999&limit=1&timeout=0`
    }, res => { res.resume(); res.on('end', resolve); });
    req.on('error', resolve);
    req.setTimeout(5000, () => { req.destroy(); resolve(); });
    req.end();
  });
}

async function startBot(attempt = 1) {
  try {
    if (attempt === 1) {
      console.log('Clearing any stale Telegram sessions...');
      await clearTelegramSessions();
      await new Promise(r => setTimeout(r, 3000));
    }
    await bot.start({
      onStart: info => {
        console.log(E.robot + ' JARVIS v9 (@' + info.username + ') PID ' + process.pid);
        console.log('Telegram polling active ✅');
      },
      drop_pending_updates: true,
      allowed_updates: ['message', 'callback_query'],
    });
  } catch (err) {
    const is409 = err.message?.includes('409');
    if (is409) {
      // CRITICAL: do NOT call Telegram again during wait — it resets the timer
      const delay = Math.min(attempt * 45000, 300000);
      console.log(`409 conflict (attempt ${attempt}) — pure wait ${delay/1000}s (no Telegram calls)...`);
      await new Promise(r => setTimeout(r, delay));
      startBot(attempt + 1);
    } else {
      console.error(`Bot error: ${err.message}`);
      await new Promise(r => setTimeout(r, 10000));
      startBot(1);
    }
  }
}

startBot();
