// ── /sys — System control commands ───────────────────────────────────
bot.command('sys', async ctx=>{
const args = ctx.message.text.split(' ').slice(1);
const cmd = args[0]?.toLowerCase();
const params = args.slice(1).join(' ');
await ctx.reply(E.zap+' Processing system command...');

switch(cmd) {
case 'info':
const info = SystemControl.getSystemInfo();
if(info.success) {
await ctx.reply(
E.check+` *System Info*\n\n`+
`• Platform: ${info.info.platform} ${info.info.arch}\n`+
`• Hostname: ${info.info.hostname}\n`+
`• CPUs: ${info.info.cpus} cores\n`+
`• Memory: ${info.info.freemem}/${info.info.totalmem}GB free\n`+
`• Uptime: ${Math.floor(info.info.uptime/3600)}h ${Math.floor((info.info.uptime%3600)/60)}m`,
{parse_mode:'Markdown'});
}
break;

case 'open':
if(!params) { await ctx.reply(E.red+' Usage: /sys open <app name>'); break; }
const openResult = await SystemControl.openApp(params);
await ctx.reply(openResult.success ? E.check+' '+openResult.message : E.red+' '+openResult.error);
break;

case 'close':
if(!params) { await ctx.reply(E.red+' Usage: /sys close <app name>'); break; }
const closeResult = await SystemControl.closeApp(params);
await ctx.reply(closeResult.success ? E.check+' '+closeResult.message : E.red+' '+closeResult.error);
break;

case 'volume':
if(!params) { await ctx.reply(E.red+' Usage: /sys volume <0-100>'); break; }
const vol = parseInt(params);
const volResult = await SystemControl.setVolume(vol);
await ctx.reply(volResult.success ? E.check+' '+volResult.message : E.red+' '+volResult.error);
break;

case 'screenshot':
const shot = await SystemControl.takeScreenshot();
await ctx.reply(shot.success ? E.check+` Screenshot saved: ${shot.filename}` : E.red+' '+shot.error);
break;

case 'run':
if(!params) { await ctx.reply(E.red+' Usage: /sys run <command>'); break; }
const runResult = await SystemControl.runCommand(params);
if(runResult.success) {
const output = runResult.stdout.slice(0, 3000) || '(no output)';
await ctx.reply(E.check+` Executed:\n\`\`\`\n${output}\n\`\`\``, {parse_mode:'Markdown'});
} else {
await ctx.reply(E.red+' '+runResult.error);
}
break;

case 'notify':
if(!params) { await ctx.reply(E.red+' Usage: /sys notify <message>'); break; }
await SystemControl.notify('JARVIS', params);
await ctx.reply(E.check+' Notification sent, sir.');
break;

case 'url':
if(!params) { await ctx.reply(E.red+' Usage: /sys url <url>'); break; }
const urlResult = await SystemControl.openURL(params);
await ctx.reply(urlResult.success ? E.check+' '+urlResult.message : E.red+' '+urlResult.error);
break;

default:
await ctx.reply(
E.laptop+' *System Commands*\n\n'+
'`/sys info` — Show system information\n'+
'`/sys open <app>` — Open application\n'+
'`/sys close <app>` — Close application\n'+
'`/sys volume <0-100>` — Set volume\n'+
'`/sys screenshot` — Take screenshot\n'+
'`/sys run <cmd>` — Execute command\n'+
'`/sys notify <msg>` — Send notification\n'+
'`/sys url <url>` — Open URL in browser',
{parse_mode:'Markdown'});
}
});

