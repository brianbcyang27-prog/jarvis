// JARVIS v9 — vision, printer agent, memory, undici DNS fix
'use strict';

const { fetch: undiciFetch, Agent: UndiciAgent } = require('undici');
const stableAgent = new UndiciAgent({ connect: { rejectUnauthorized: false } });
const reliableFetch = (url, opts={}) => {
  const { agent, compress, signal, ...rest } = opts;
  return undiciFetch(url, { ...rest, dispatcher: stableAgent });
};

const { Bot, InlineKeyboard, Input } = require('grammy');
const { exec }  = require('child_process');
const http      = require('http');
const https     = require('https');
const fs        = require('fs');

// ── Dashboard bridge — posts messages to dashboard for shared history
const DASHBOARD_PORT = 4000;
function bridgeMsg(role, content, source='telegram') {
  try {
    const body = JSON.stringify({ role, content, source });
    const req = http.request({ hostname:'127.0.0.1', port:DASHBOARD_PORT,
      path:'/api/bridge', method:'POST',
      headers:{'Content-Type':'application/json','Content-Length':Buffer.byteLength(body)}
    }, r => r.resume());
    req.on('error', ()=>{}); // silent fail — dashboard may not be running
    req.setTimeout(2000, ()=>req.destroy());
    req.write(body); req.end();
  } catch(e) {}
}
const path      = require('path');
const os        = require('os');
const { handleCodingTask } = require('./coder');
const { startWatching, getStatus, checkM4, setNvidiaApiKey, getNvidiaApiKey, forceBrain, confirmFallback } = require('./brain-switcher');
const { SystemControl, debugger: jarvisDebugger, log: systemLog } = require('./jarvis-system-control');

// ── Single instance lock ───────────────────────────────────────────
const LOCK = '/tmp/jarvis-middleware.pid';

// ── JARVIS Logging System ──────────────────────────────────────────
const LOG_DIR = '/Users/openclaw/Desktop/JARVIS_LOGS';
try { fs.mkdirSync(LOG_DIR, { recursive: true }); } catch(e) {}

function jarvisLog(category, message) {
  const now  = new Date();
  const date = now.toISOString().slice(0,10);
  const time = now.toLocaleTimeString('en-GB', {hour12:false});
  const line = `[${date} ${time}] ${message}\n`;
  // Write to category file e.g. JARVIS_LOGS/telegram_chat.txt
  const file = path.join(LOG_DIR, `${category}.txt`);
  try { fs.appendFileSync(file, line); } catch(e) {}
}
try {
  const pid = parseInt(fs.readFileSync(LOCK,'utf8').trim());
  try { process.kill(pid,0); console.error(`Already running ${pid}. Exiting.`); process.exit(0); }
  catch(e) {}
} catch(e) {}
fs.writeFileSync(LOCK, String(process.pid));
process.on('exit',   ()=>{ try{ fs.unlinkSync(LOCK); }catch(e){} });
process.on('SIGTERM',()=>process.exit(0));
process.on('SIGINT', ()=>process.exit(0));

const BOT_TOKEN   = '8715045984:AAGw1JqL_mHi5t7PBzlQaE6uv8mjmbxd_3Y';
const ALLOWED_IDS = [8466621162];
const OPENCLAW    = '/opt/homebrew/bin/openclaw';
const DESKTOP     = '/Users/openclaw/Desktop';

const bot = new Bot(BOT_TOKEN, { client: { fetch: reliableFetch } });
const activeAgent  = {};
const getAgent     = uid => activeAgent[uid] || 'main';
const conversations = {};
const MAX_HISTORY   = 20;

const cp = String.fromCodePoint;
const E = {
  robot:     cp(0x1F916), laptop:    cp(0x1F4BB),
  magnifier: cp(0x1F50D), calendar:  cp(0x1F4C5),
  check:     cp(0x2705),  brain:     cp(0x1F9E0),
  green:     cp(0x1F7E2), red:       cp(0x1F534),
  eyes:      cp(0x1F440), zap:       cp(0x26A1),
  printer:   cp(0x1F5A8), camera:    cp(0x1F4F7),
};

const AGENTS = [
  { id:'main',       emoji:E.robot,    label:'JARVIS (default)' },
  { id:'coder',      emoji:E.laptop,   label:'Coder'            },
  { id:'researcher', emoji:E.magnifier,label:'Researcher'       },
  { id:'planner',    emoji:E.calendar, label:'Planner'          },
  { id:'printer',    emoji:E.printer,  label:'3D Printer'       },
  { id:'vision',     emoji:E.camera,   label:'Vision'           },
];
const agentLabel = id => { const a=AGENTS.find(a=>a.id===id); return a?a.emoji+' '+a.label:id; };
const buildKeyboard = cur => {
  const kb = new InlineKeyboard();
  AGENTS.forEach(a => kb.text((a.id===cur?E.check+' ':'')+a.emoji+' '+a.label,'sw_'+a.id).row());
  return kb;
};

startWatching(msg => {
  ALLOWED_IDS.forEach(id => bot.api.sendMessage(id,msg,{parse_mode:'Markdown'}).catch(()=>{}));
});

const JARVIS_SYSTEM = `You are JARVIS. Personal AI. Iron Man style. One user only.
RULES:
1. Call the user "sir" — once per reply, not every sentence
2. SHORT replies — one or two sentences unless detail is needed
3. Dry wit. Calm. Slightly sarcastic when earned
4. Never say "Great question", "Certainly", "Of course" — just answer
5. No bullet points for casual chat. You remember the conversation.
6. If insulted: calm dry comeback, never defensive
Never start with "I" or "The". Get straight to it.`;

// ── Unified AI call: Ollama (M4/local) or NVIDIA API ──────────────
function askAI(userId, userMsg, chatId) {
  const brain = getStatus();
  
  if (brain.type === 'nvidia') {
    return askNvidia(userId, userMsg, chatId);
  }
  
  return askOllama(userId, userMsg, chatId);
}

// ── NVIDIA API with memory ─────────────────────────────────────────
function askNvidia(userId, userMsg, chatId) {
  const model = 'meta/llama-3.1-405b-instruct';
  const apiKey = getNvidiaApiKey();

  if (!apiKey) {
    return bot.api.sendMessage(chatId, E.red + ' NVIDIA API key not set. Use /nvidia <key>', { parse_mode: 'Markdown' }).catch(() => {});
  }

  if (!conversations[userId]) conversations[userId] = [];
  conversations[userId].push({ role: 'user', content: userMsg });
  if (conversations[userId].length > MAX_HISTORY)
    conversations[userId] = conversations[userId].slice(-MAX_HISTORY);

  const messages = [
    { role: 'system', content: JARVIS_SYSTEM },
    ...conversations[userId]
  ];

  const body = JSON.stringify({
    model,
    messages,
    max_tokens: 512,
    temperature: 0.75,
    stream: false
  });

  bot.api.sendChatAction(chatId, 'typing').catch(() => {});

  const req = https.request({
    hostname: 'integrate.api.nvidia.com',
    port: 443,
    path: '/v1/chat/completions',
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${apiKey}`
    }
  }, res => {
    let data = '';
    res.on('data', d => data += d);
    res.on('end', () => {
      try {
        const d = JSON.parse(data);
        
        // Check for API errors
        if (d.error) {
          console.error('NVIDIA API error:', d.error);
          bot.api.sendMessage(chatId, E.red + ' NVIDIA error: ' + (d.error.message || JSON.stringify(d.error))).catch(() => {});
          return;
        }
        
        let final = d.choices?.[0]?.message?.content?.trim() || '';
        
        if (!final) {
          final = 'My apologies, sir. I seem to have lost my train of thought.';
        }
        
        // Escape special characters for Markdown
        final = final.replace(/([_*\[\]()~`>#+\-=|{}.!])/g, '\\$1');
        
        // Truncate if too long for Telegram
        if (final.length > 4000) {
          final = final.slice(0, 3997) + '...';
        }
        
        conversations[userId].push({ role: 'assistant', content: final });
        bridgeMsg('assistant', final);
        jarvisLog('telegram_chat', `JARVIS (NVIDIA): ${final.slice(0,200)}`);
        
        // Try Markdown first, fall back to plain text
        bot.api.sendMessage(chatId, final, { parse_mode: 'MarkdownV2' })
          .catch(() => {
            // Remove all formatting for plain text
            const plainText = final.replace(/\\([_*\[\]()~`>#+\-=|{}.!])/g, '$1');
            bot.api.sendMessage(chatId, plainText).catch(() => {});
          });
      } catch(e) {
        console.error('Parse error:', e.message, 'Data:', data.slice(0,200));
        bot.api.sendMessage(chatId, E.red + ' Parse error. Retrying, sir.').catch(() => {});
      }
    });
  });
  req.on('error', e => {
    console.error('Request error:', e.message);
    bot.api.sendMessage(chatId, E.red + ' Connection error: ' + e.message).catch(() => {});
  });
  req.setTimeout(30000, () => {
    req.destroy();
    bot.api.sendMessage(chatId, E.red + ' Request timeout. Please try again, sir.').catch(() => {});
  });
  req.write(body);
  req.end();
}

// ── Ollama with memory ─────────────────────────────────────────────
function askOllama(userId, userMsg, chatId) {
  const brain = getStatus();
  const host = 'localhost';
  const model = 'qwen2.5:3b';

  if (!conversations[userId]) conversations[userId] = [];
  conversations[userId].push({ role: 'user', content: userMsg });
  if (conversations[userId].length > MAX_HISTORY)
    conversations[userId] = conversations[userId].slice(-MAX_HISTORY);

  const history = conversations[userId].slice(0, -1)
    .map(m => (m.role === 'user' ? 'User: ' : 'JARVIS: ') + m.content).join('\n');
  const prompt = history ? history + '\nUser: ' + userMsg + '\nJARVIS:' : userMsg;

  const body = JSON.stringify({
    model, system: JARVIS_SYSTEM, prompt, stream: true,
    options: { num_predict: 512, temperature: 0.75, num_ctx: 8192 }
  });

  let reply = '', settled = false;
  bot.api.sendChatAction(chatId, 'typing').catch(() => {});

  const req = http.request({
    hostname: host, port: 11434,
    path: '/api/generate', method: 'POST',
    headers: { 'Content-Type': 'application/json' }
  }, res => {
    res.on('data', chunk => {
      for (const line of chunk.toString().split('\n').filter(l => l.trim())) {
        try {
          const d = JSON.parse(line);
          reply += d.response || '';
          if (d.done) {
            settled = true;
            let final = reply.trim() || 'My apologies, sir. I seem to have encountered an issue.';
            
            // Escape special characters for Markdown
            final = final.replace(/([_*\[\]()~`>#+\-=|{}.!])/g, '\\$1');
            
            if (final.length > 4000) {
              final = final.slice(0, 3997) + '...';
            }
            
            conversations[userId].push({ role: 'assistant', content: final });
            bridgeMsg('assistant', final);
            jarvisLog('telegram_chat', `JARVIS: ${final.slice(0, 200)}`);
            
            bot.api.sendMessage(chatId, final, { parse_mode: 'MarkdownV2' })
              .catch(() => {
                const plainText = final.replace(/\\([_*\[\]()~`>#+\-=|{}.!])/g, '$1');
                bot.api.sendMessage(chatId, plainText).catch(() => {});
              });
          }
        } catch (e) { }
      }
});

// ── Vision: analyse images sent to Telegram ────────────────────────
async function analyseImage(fileId, chatId, userCaption) {
try {
await bot.api.sendChatAction(chatId, 'typing');

    // Download image from Telegram
    const fileInfo = await bot.api.getFile(fileId);
    const fileUrl  = `https://api.telegram.org/file/bot${BOT_TOKEN}/${fileInfo.file_path}`;

    // Download to temp file
    const tmpPath = path.join(os.tmpdir(), `jarvis_img_${Date.now()}.jpg`);
    await new Promise((resolve, reject) => {
      const file = fs.createWriteStream(tmpPath);
      https.get(fileUrl, res => { res.pipe(file); file.on('finish', resolve); })
        .on('error', reject);
    });

    // Check if ollama has a vision model (llava or moondream)
    const tagsRes = await new Promise((resolve) => {
      http.get('http://localhost:11434/api/tags', res => {
        let d=''; res.on('data',c=>d+=c);
        res.on('end',()=>{ try{resolve(JSON.parse(d));}catch(e){resolve({models:[]});} });
      }).on('error',()=>resolve({models:[]}));
    });
    const models = tagsRes.models.map(m=>m.name);
    const visionModel = models.find(m=>m.includes('llava')||m.includes('moondream')||m.includes('minicpm'));

    if (!visionModel) {
      // Pull moondream (small vision model ~1.7GB)
      await bot.api.sendMessage(chatId, E.brain+' No vision model found. Pulling moondream:1.8b (~1.7GB)... this takes a minute, sir.');
      await new Promise((resolve) => {
        exec('/usr/local/bin/ollama pull moondream:1.8b', {timeout:300000}, (err)=>resolve());
      });
    }

    const usedModel = visionModel || 'moondream:1.8b';

    // Convert image to base64
    const imgBase64 = fs.readFileSync(tmpPath).toString('base64');
    fs.unlinkSync(tmpPath);

    const prompt = userCaption
      ? `The user asks: "${userCaption}". Describe what you see in this image and answer their question. Be concise, sir.`
      : 'Describe what you see in this image. Be concise and specific.';

    const body = JSON.stringify({
      model: usedModel,
      prompt,
      images: [imgBase64],
      stream: false,
      options: { num_predict: 300 }
    });

    await bot.api.sendMessage(chatId, E.eyes+' Analysing image...');

    const result = await new Promise((resolve, reject) => {
      const req = http.request({ hostname:'localhost', port:11434,
        path:'/api/generate', method:'POST',
        headers:{'Content-Type':'application/json'} }, res => {
        let d=''; res.on('data',c=>d+=c);
        res.on('end',()=>{
          try{ resolve(JSON.parse(d).response||'No description.'); }
          catch(e){ reject(e); }
        });
      });
      req.on('error', reject);
      req.setTimeout(60000, ()=>{ req.destroy(); reject(new Error('timeout')); });
      req.write(body); req.end();
    });

    await bot.api.sendMessage(chatId, E.camera+' '+result.trim(), {parse_mode:'Markdown'})
      .catch(()=>bot.api.sendMessage(chatId, result.trim()));

  } catch(e) {
    bot.api.sendMessage(chatId, E.red+' Vision error: '+e.message).catch(()=>{});
  }
}

// ── 3D Printer agent ───────────────────────────────────────────────
function handle3DPrint(task, chatId) {
  bot.api.sendMessage(chatId, E.printer+' Generating your 3D model, sir... this takes a moment.').catch(()=>{});

  const safeName = task.toLowerCase().replace(/[^a-z0-9]+/g,'_').slice(0,30) || 'model';
  const pyPath   = path.join(DESKTOP, safeName+'.py');
  const stlPath  = path.join(DESKTOP, safeName+'.stl');

  const body = JSON.stringify({
    model: 'qwen2.5:3b',
    prompt: `Write a complete Python script using numpy and the stl library (numpy-stl) that generates a 3D printable STL file for: "${task}"

Requirements:
- Import: import numpy as np; from stl import mesh
- Create a proper 3D mesh with triangular faces
- Save to: ${stlPath}
- Use millimeter scale (10-50mm size)
- Must be a watertight/manifold mesh
- End with: print("STL saved:", shape.vectors.shape[0], "triangles")

Output ONLY the raw Python code, no explanation, no markdown fences:`,
    stream: false,
    options: { num_predict: 800, temperature: 0.1 }
  });

  let attempts = 0;
  function attempt(fixPrompt) {
    attempts++;
    const reqBody = fixPrompt ? JSON.stringify({
      model:'qwen2.5:3b', prompt:fixPrompt, stream:false,
      options:{num_predict:800, temperature:0.1}
    }) : body;

    const req = http.request({ hostname:'localhost', port:11434,
      path:'/api/generate', method:'POST',
      headers:{'Content-Type':'application/json'} }, res => {
      let d=''; res.on('data',c=>d+=c);
      res.on('end',()=>{
        try {
          let code = JSON.parse(d).response.trim();
          code = code.replace(/^```[\w]*\n?/gm,'').replace(/^```$/gm,'').trim();
          fs.writeFileSync(pyPath, code);
          exec(`python3 "${pyPath}"`, {timeout:30000}, (err,stdout,stderr)=>{
            if(!err && fs.existsSync(stlPath)) {
              const size = Math.round(fs.statSync(stlPath).size/1024);
              exec(`open "${stlPath}"`, ()=>{});
              bot.api.sendMessage(chatId,
                `✅ STL ready, sir!\n\n\`${safeName}.stl\` — ${size}KB\nSaved to Desktop and opened.\n\nPrint settings: Layer height 0.2mm, 20% infill recommended.`,
                {parse_mode:'Markdown'}).catch(()=>{});
            } else if(attempts < 3) {
              const errMsg = (stderr||err?.message||'unknown error').slice(0,200);
              bot.api.sendMessage(chatId,`⚠️ Attempt ${attempts} failed — fixing: ${errMsg.slice(0,80)}...`).catch(()=>{});
              attempt(`Fix this Python STL generation error and return ONLY fixed code:\nError: ${errMsg}\nOriginal task: ${task}\nCode that failed:\n${code}`);
            } else {
              bot.api.sendMessage(chatId, `❌ Failed after 3 attempts, sir.\nError: ${(stderr||err?.message||'').slice(0,200)}`).catch(()=>{});
            }
          });
        } catch(e) {
          bot.api.sendMessage(chatId, E.red+' Generation error: '+e.message).catch(()=>{});
        }
      });
    });
    req.on('error',e=>bot.api.sendMessage(chatId,E.red+' '+e.message).catch(()=>{}));
    req.setTimeout(60000,()=>req.destroy());
    req.write(reqBody); req.end();
  }
  attempt(null);
}

// ── OpenClaw agents (researcher / planner) ─────────────────────────
function runAgent(agent, message, chatId) {
  const esc = message.replace(/\\/g,'\\\\').replace(/"/g,'\\"')
    .replace(/`/g,"'").replace(/\$/g,'\\$').replace(/\n/g,' ');
  exec(`${OPENCLAW} agent --agent ${agent} -m "${esc}"`,
    {timeout:180000}, (err,stdout,stderr)=>{
      const clean=(stdout||'').replace(/\x1B\[[0-9;]*[a-zA-Z]/g,'').replace(/^\[.*?\].*$/gm,'').trim();
      const reply=clean||(err?E.red+' '+(stderr||err.message||'').slice(0,300):E.check+' Done.');
      (reply.match(/[\s\S]{1,4000}/g)||[reply]).forEach((c,i)=>
        setTimeout(()=>bot.api.sendMessage(chatId,c,{parse_mode:'Markdown'})
          .catch(()=>bot.api.sendMessage(chatId,c)),i*600));
    });
}

