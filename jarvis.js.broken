    const current = getNvidiaApiKey();
    await ctx.reply(
      E.brain+' *NVIDIA API Status*\n\n' +
      (current ? `✅ Key set: \`${current.slice(0,8)}...\`\n` : '❌ No key set\n') +
      'Usage: `/nvidia nvapi-xxx`\n\n' +
      '_Key activates NVIDIA 405B cloud brain._',
      {parse_mode: 'Markdown'});
